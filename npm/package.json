{
  "name": "git-userhub",
  "version": "3.0.0",
  "description": "Switch Git accounts in one command. No config editing. No SSH key chaos.",
  "bin": {
    "git-user": "bin/git-user.js"
  },
  "scripts": {
    "postinstall": "node install.js",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "dependencies": {
    "tar": "^7.4.3"
  },
  "keywords": [
    "git",
    "github",
    "gitlab",
    "ssh",
    "identity",
    "account",
    "switch",
    "cli",
    "developer-tools"
  ],
  "author": "Divyo Argha",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/divyo-argha/git-user.git"
  },
  "bugs": {
    "url": "https://github.com/divyo-argha/git-user/issues"
  },
  "homepage": "https://github.com/divyo-argha/git-user#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "socket": {
    "allowedNetworkHosts": [
      "api.github.com",
      "github.com",
      "objects.githubusercontent.com"
    ]
  },
  "config": {
    "repo": "divyo-argha/git-user"
  }
}
